{
  "name": "flopsstuff",
  "private": true,
  "description": "Flopsstuff — static stub on Cloudflare Workers",
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "wrangler": "3.107.3"
