# Cloudflare credentials for `yarn deploy` (and mirror these into GitHub Secrets for CI).
# Copy this file to `.env` and fill in the values. `.env` is gitignored.

# API token: My Profile -> API Tokens -> Create Custom Token.
# Permissions: Workers Scripts:Edit, Account Settings:Read, Workers Routes:Edit, DNS:Edit (zone aignite.pl).
CLOUDFLARE_API_TOKEN=

# Account ID (not secret) — from `wrangler whoami` / dashboard.
CLOUDFLARE_ACCOUNT_ID=42548ca95c85a68b4ce20ad79b805334
